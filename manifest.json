{
  "manifest_version": 3,
  "name": "JLI LinkedIn Declutter",
  "description": "Locally hides and collapses LinkedIn feed and notification clutter.",
  "version": "1.4.3",
  "browser_specific_settings": {
    "gecko": {
      "id": "jli-declutter@jacebenson",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "icons": {
    "128": "assets/icon-128.png"
  },
  "permissions": ["storage", "activeTab"],
  "action": {
    "default_title": "JLI Declutter",
    "default_icon": "assets/icon-128.png",
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "browser_style": true
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content/generator.js"],
      "run_at": "document_idle"
    }
  ]
}
