{
  "manifest_version": 3,
  "name": "JLI LinkedIn Declutter",
  "description": "Locally hides and collapses LinkedIn feed and notification clutter.",
  "version": "1.3.0",
  "icons": {
    "128": "assets/icon-128.png"
  },
  "action": {
    "default_title": "JLI Declutter",
    "default_icon": "assets/icon-128.png"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
